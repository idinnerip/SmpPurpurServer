# 1. Ignore EVERYTHING in the root directory
/*
!config/*
# 2. Un-ignore the specific folders you need 
# (We use / at the end so it knows it's a folder)
!world/
!world_nether/

# 3. Now, tell Git what to ignore INSIDE those folders
world/*
!world/datapacks/

world_nether/*
!world_nether/paper-world.yml

plugins/*
# 2. Inside plugins: ignore everything but allow specific JARs and specific folders
!plugins/*.jar

# List the folders you want Git to look into
!plugins/AxGraves/
!plugins/CombatTag/
!plugins/Essentials/
!plugins/LuckPerms/
!plugins/TAB/
!plugins/UltimateTeams/
!plugins/WorldEvents/

# 3. Now un-ignore the specific files inside those folders
!plugins/AxGraves/config.yml
!plugins/CombatTag/config.yml
!plugins/Essentials/config.yml
!plugins/LuckPerms/yaml-storage/
!plugins/LuckPerms/config.yml
!plugins/TAB/config.yml
!plugins/UltimateTeams/config.yml
!plugins/WorldEvents/config.yml
!plugins/WorldEvents/menus.yml
!plugins/WorldEvents/events/

# 4. Un-ignore specific root files
!spigot.yml
!eula.txt
!server.properties
!server-icon.png
!run.bat
!purpur.yml
!ops.json
!bukkit.yml
!.gitignore

# 5. Specifically block common junk that might bypass rules
*.log
*.log.gz
*.old
cache/
libraries/
versions/
logs/
